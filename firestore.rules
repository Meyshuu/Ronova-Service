rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwnerOrAdmin() {
      return request.auth != null && request.auth.token.role in ['owner', 'admin'];
    }

    match /appState/web-joki {
      // Read access is open for the demo app. Restrict this further if needed.
      allow read: if true;

      // Writes must come from authenticated owner/admin accounts.
      // The Firebase Admin SDK bypasses rules, so server-side webhook updates still succeed.
      allow create, update, delete: if isOwnerOrAdmin();
    }
  }
}
